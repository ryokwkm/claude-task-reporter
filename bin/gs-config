#!/bin/bash
# タスク完了通知 hook の ON/OFF をトグルする

set -eu

CONF="$HOME/.claude/hooks/claude-task-reporter/session_summary.conf"

if [ ! -f "$CONF" ]; then
    echo "設定ファイルが見つかりません: $CONF" >&2
    exit 1
fi

if grep -q "^ENABLED=true" "$CONF"; then
    sed -i "" "s/^ENABLED=true/ENABLED=false/" "$CONF"
    echo "タスク完了通知 hook: OFF"
elif grep -q "^ENABLED=false" "$CONF"; then
    sed -i "" "s/^ENABLED=false/ENABLED=true/" "$CONF"
    echo "タスク完了通知 hook: ON"
else
    echo "ENABLED の値が true/false ではありません: $CONF" >&2
    exit 1
fi
